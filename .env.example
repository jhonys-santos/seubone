# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA commite o arquivo ".env" (ele já está no .gitignore).

# Porta que o servidor vai escutar localmente
PORT=3000

# String aleatória longa usada para assinar o cookie de sessão.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-uma-string-aleatoria-longa

# Onde ficam as sessões salvas (os usuários ficam na planilha, não aqui).
# Deixe em branco para rodar localmente (usa a pasta data/ do próprio
# projeto). Em produção (Render), como não tem disco persistente, deixe em
# branco também — só a sessão de quem já estava logado se perde num deploy
# novo, não o cadastro de ninguém.
DATA_DIR=

# Código de acesso da tela /setup (criar/atualizar usuário pelo navegador,
# sem precisar de Shell — necessário no plano Free da Render, que não tem
# terminal). Gere uma string aleatória, ex:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SETUP_TOKEN=

# URLs dos Web Apps do Google Apps Script (Extensões > Apps Script > Implantar > Nova implantação > Web app)
WALLAC_APPS_SCRIPT_URL=
PEDIDOS_URGENTES_APPS_SCRIPT_URL=
PAINEL_SAC_APPS_SCRIPT_URL=

# Segredo compartilhado enviado em todo request do servidor para o Apps Script,
# e validado dentro do próprio script do Google (ver README, seção "Proteger o Apps Script").
# OBRIGATÓRIO: é o que autoriza o hub a ler/escrever a aba HubUsuarios (onde
# ficam os logins/senhas do hub) na planilha do Painel SAC.
APPS_SCRIPT_SHARED_SECRET=troque-por-outra-string-aleatoria

# URLs dos CSVs publicados do Google Sheets usados no Ranking SAC
# (Arquivo > Compartilhar > Publicar na Web > escolher a aba > formato CSV)
RANKING_SAC_CSV_ATD=
RANKING_SAC_CSV_RSL=
RANKING_SAC_CSV_KPI=
RANKING_SAC_CSV_AGENDA=
