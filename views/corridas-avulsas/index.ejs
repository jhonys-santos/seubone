<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('../partials/head') %>
<title>Corridas Avulsas — SeuBoné</title>
<link rel="stylesheet" href="/css/pedidos-urgentes.css">
<link rel="stylesheet" href="/css/corridas-avulsas.css">
</head>
<body>
<div class="app-shell">
<%- include('../partials/sidebar') %>
<div class="app-main">

<div class="pu-scope">
<div class="pu-container ca-container">

  <div class="card">
    <div class="ca-titulo"><i class="ti ti-truck-delivery" aria-hidden="true"></i> Registrar corrida avulsa</div>

    <label>Data da corrida *</label>
    <input type="date" id="caData">

    <div class="row2">
      <div>
        <label>Número da NF *</label>
        <input type="text" id="caNf" placeholder="Ex: 12345">
      </div>
      <div>
        <label>Valor da corrida (R$) *</label>
        <input type="number" id="caValor" placeholder="Ex: 25.00" step="0.01" min="0">
      </div>
    </div>

    <label>Endereço de entrega *</label>
    <input type="text" id="caEndereco" placeholder="Endereço completo da entrega">

    <label>Nome do motorista *</label>
    <input type="text" id="caMotorista" list="ca-lista-motoristas" placeholder="Ex: Matheus">
    <datalist id="ca-lista-motoristas">
      <option value="Matheus">
      <option value="Rodolfo">
      <option value="Rilberto">
      <option value="Thamy">
      <option value="Deide">
    </datalist>

    <label>Print do motorista (valor cobrado) *</label>
    <input type="file" id="caPrint" accept="image/*" multiple>
    <div class="ca-hint" id="caArquivosInfo"></div>

    <div style="font-size:12px;color:var(--text-muted);margin-top:16px;display:flex;align-items:center;gap:6px;"><i class="ti ti-user-circle" aria-hidden="true"></i> Registrando como <strong style="color:var(--text)"><%= usuario.nome %></strong></div>
    <button class="btn-primary" id="caBtnEnviar" onclick="caEnviar()"><i class="ti ti-send" aria-hidden="true"></i> Registrar corrida</button>

    <div class="msg" id="caMsg"></div>
  </div>

  <div class="card ca-semana-card">
    <div class="ca-semana-head">
      <button type="button" class="ca-nav-btn" onclick="caNavegarSemana(-1)" aria-label="Semana anterior"><i class="ti ti-chevron-left" aria-hidden="true"></i></button>
      <div class="ca-semana-titulo">
        <i class="ti ti-calendar-week" aria-hidden="true"></i>
        <span id="caSemanaLabel">Semana</span>
      </div>
      <button type="button" class="ca-nav-btn" onclick="caNavegarSemana(1)" aria-label="Próxima semana"><i class="ti ti-chevron-right" aria-hidden="true"></i></button>
    </div>
    <div class="ca-hint">Tire um print desta lista e envie para o financeiro na sexta-feira.</div>

    <div class="ca-filtro-row">
      <label for="caFiltroMotorista">Motorista</label>
      <select id="caFiltroMotorista" onchange="caRenderLista()">
        <option value="">Todos</option>
      </select>
    </div>

    <div id="caLista"></div>

    <div class="ca-total-row">
      <span>Total a solicitar</span>
      <strong id="caTotal">R$ 0,00</strong>
    </div>

    <button class="btn-primary" id="caBtnSolicitarPagamento" style="display:none" onclick="caAbrirPagamento()">
      <i class="ti ti-cash" aria-hidden="true"></i> Solicitar pagamento
    </button>
  </div>

</div>
</div>

<!-- MODAL SOLICITAR PAGAMENTO -->
<div class="modal-overlay" id="modal-pagamento" onclick="if(event.target===this)caFecharPagamento()">
  <div class="modal-box" style="max-width:640px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <div>
        <div style="font-size:15px;font-weight:700"><i class="ti ti-cash" style="color:var(--gold);margin-right:6px"></i>Solicitar pagamento</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Manda direto pro financeiro</div>
      </div>
      <button onclick="caFecharPagamento()" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1;padding:4px"><i class="ti ti-x"></i></button>
    </div>

    <div class="row2">
      <div>
        <label>Razão social *</label>
        <input type="text" id="pgRazaoSocial" placeholder="Nome de quem vai receber o pagamento">
      </div>
      <div>
        <label>Seu nome *</label>
        <input type="text" id="pgSolicitante" list="pg-lista-solicitantes" placeholder="Quem está solicitando">
        <datalist id="pg-lista-solicitantes">
          <option value="Nathalia Guedes">
          <option value="Iasmin Silva">
          <option value="Francis Medeiros">
          <option value="Daniel Sheldon">
          <option value="Wallac Mauricio">
          <option value="Gabrielle Batista">
          <option value="Jhonys Santos">
        </datalist>
      </div>
    </div>

    <div class="row2">
      <div>
        <label>Data de vencimento *</label>
        <input type="date" id="pgVencimento">
      </div>
      <div>
        <label>CPF/CNPJ *</label>
        <input type="text" id="pgCpfCnpj" placeholder="Inserir texto">
      </div>
    </div>

    <label>E-mail do solicitante *</label>
    <input type="email" id="pgEmail" placeholder="Inserir e-mail">

    <label>Motivo do pagamento *</label>
    <textarea id="pgMotivo" rows="2" placeholder="Inserir texto"></textarea>

    <div class="row2">
      <div>
        <label>Banco *</label>
        <select id="pgBanco">
          <option value="">Selecionar opção...</option>
          <option>Banco do Brasil</option>
          <option>Itaú</option>
          <option>Bradesco</option>
          <option>Santander</option>
          <option>Caixa Econômica Federal</option>
          <option>Nubank</option>
          <option>Banco Inter</option>
          <option>C6 Bank</option>
          <option>Sicoob</option>
          <option>Sicredi</option>
          <option>Outro</option>
        </select>
      </div>
      <div>
        <label>Agência *</label>
        <input type="text" id="pgAgencia" placeholder="Inserir número">
      </div>
    </div>

    <div class="row2">
      <div>
        <label>Conta *</label>
        <input type="text" id="pgConta" placeholder="Inserir texto">
      </div>
      <div>
        <label>Chave pix *</label>
        <input type="text" id="pgChavePix" placeholder="Inserir texto">
      </div>
    </div>

    <div class="row2">
      <div>
        <label>Tipo de chave</label>
        <select id="pgTipoChave">
          <option value="">Selecionar opção...</option>
          <option>CPF</option>
          <option>CNPJ</option>
          <option>E-mail</option>
          <option>Telefone</option>
          <option>Aleatória</option>
        </select>
      </div>
      <div>
        <label>Valor *</label>
        <input type="text" id="pgValor" placeholder="Ex: 150,00">
      </div>
    </div>

    <div class="row2">
      <div>
        <label>Número da Nota Fiscal</label>
        <input type="text" id="pgNumeroNf" placeholder="Inserir número">
      </div>
      <div>
        <label>Empresa Responsável *</label>
        <select id="pgEmpresa">
          <option value="">Selecionar opção...</option>
          <option>SeuBoné</option>
        </select>
      </div>
    </div>

    <label>Anexos</label>
    <div style="font-size:12px;color:var(--text-muted);margin:0 0 6px;">Adicione, se houver, comprovantes ou notas para a solicitação</div>
    <input type="file" id="pgAnexos" multiple>

    <button class="btn-primary" id="pgBtnEnviar" onclick="caEnviarPagamento()"><i class="ti ti-send" aria-hidden="true"></i> Enviar solicitação</button>
    <div class="msg" id="pgMsg"></div>
  </div>
</div>

</div>
</div>

<script src="/js/corridas-avulsas.js"></script>
</body>
</html>
