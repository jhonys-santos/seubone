<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('../partials/head') %>
<title>Meus Indicadores — SeuBoné</title>
<link rel="stylesheet" href="/css/painel-sac.css">
</head>
<body>
<!-- LOADING PAINEL -->
<div class="loading-screen show" id="loading-screen">
  <div class="loading-logo">
    <img src="/img/logo-seubone.png" alt="SeuBoné" style="width:32px;height:32px;object-fit:contain;">
    <span>SeuBoné</span>
  </div>
  <div class="loading-bar"><div class="loading-fill"></div></div>
  <div class="loading-txt" id="loading-txt">Carregando seu painel...</div>
</div>

<div class="app-shell">
<%- include('../partials/sidebar') %>
<div class="app-main">

<!-- PAINEL -->
<div class="dash" id="dash">
  <div id="error-banner" class="error-banner"></div>
  <div class="topbar">
    <div class="left-info">
      <div class="slabel" style="margin-bottom:0">Painel de indicadores</div>
    </div>
    <div class="topbar-right">
      <% if (outrosColaboradores.length) { %>
      <div class="ver-como-wrap">
        <span class="tag">Gestor</span>
        <select class="ver-como-select" id="ver-como-select" onchange="trocarVerComo(this.value)">
          <option value="">Ver meus indicadores</option>
          <% outrosColaboradores.forEach(function(c) { %>
            <option value="<%= c.slug %>">Ver como: <%= c.nome %></option>
          <% }); %>
        </select>
      </div>
      <% } %>
      <button class="logout-btn" onclick="abrirAcessos()" style="border-color:var(--gold-dark);color:var(--gold);"><i class="ti ti-key" style="font-size:13px"></i> Acessos</button>
    </div>
  </div>
  <div class="filter-bar">
    <div class="tabs">
      <button class="tab active" onclick="setPeriodo('semana',this)">Semana</button>
      <button class="tab" onclick="setPeriodo('mes',this)">Mês</button>
    </div>
    <div class="week-select-wrap" id="week-select-wrap">
      <select class="week-select" id="week-select" onchange="setSemana(parseInt(this.value))"></select>
    </div>
    <select class="month-select" id="month-select" onchange="setMes(this.value)">
      <option value="0">Janeiro</option><option value="1">Fevereiro</option><option value="2">Março</option>
      <option value="3">Abril</option><option value="4">Maio</option><option value="5">Junho</option>
      <option value="6">Julho</option><option value="7">Agosto</option><option value="8">Setembro</option>
      <option value="9">Outubro</option><option value="10">Novembro</option><option value="11">Dezembro</option>
    </select>
  </div>
  <div class="dash-refresh-bar" id="dash-refresh-bar"><div class="fill"></div></div>
  <div class="dash-content" id="dash-content">
  <div class="slabel" id="kpi-label">Indicadores principais</div>
  <div class="kpi-grid" id="kpi-grid"></div>
  <div id="evolucao-block"></div>
  <div class="slabel" id="pico-label">Pico de demanda</div>
  <div class="pico-card" id="pico-card"></div>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
    <div class="slabel" style="margin-bottom:0" id="audit-section-label">Auditoria de processos</div>
    <button id="btn-ver-auditorias" onclick="abrirHistoricoAuditoria()" style="display:none;background:var(--gold-dim);border:1px solid var(--gold-dark);border-radius:8px;padding:5px 12px;cursor:pointer;color:var(--gold);font-size:11px;font-weight:700;font-family:inherit;align-items:center;gap:5px">
      <i class="ti ti-clipboard-list" style="font-size:12px"></i> Ver auditorias
    </button>
  </div>
  <div class="audit-card" id="audit-block"></div>
  <div class="slabel" id="detrat-label">Insatisfeitos · CSAT</div>
  <div class="detrat-card" id="detrat-block"></div>
  <div class="slabel" id="rv-label" style="display:none">Remuneração variável · mês</div>
  <div class="rv-card" id="rv-block" style="display:none"></div>
  </div>
</div>

</div>
</div>

<!-- MODAL ACESSOS -->
<div class="modal-overlay" id="modal-acessos" onclick="if(event.target===this)fecharAcessos()">
  <div class="modal-box" style="max-width:480px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <div>
        <div style="font-size:15px;font-weight:700"><i class="ti ti-key" style="color:var(--gold);margin-right:6px"></i>Acessos</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Suas credenciais de ferramentas</div>
      </div>
      <button onclick="fecharAcessos()" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1;padding:4px"><i class="ti ti-x"></i></button>
    </div>

    <div id="acessos-lista" style="margin-bottom:1rem;display:flex;flex-direction:column;gap:8px;max-height:340px;overflow-y:auto;padding-right:2px"></div>

    <button id="btn-add-acesso" onclick="mostrarFormAcesso()" style="width:100%;background:var(--gold-dim);border:1px dashed var(--gold-dark);border-radius:var(--rs);padding:10px;font-size:12px;font-weight:600;color:var(--gold);cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s">
      <i class="ti ti-plus"></i> Adicionar acesso
    </button>

    <div id="form-acesso" style="display:none;margin-top:12px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:14px">
      <div style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--text)" id="form-acesso-titulo">Novo acesso</div>
      <input type="hidden" id="acesso-edit-idx" value="">
      <div class="field" style="margin-bottom:10px">
        <label>Ferramenta</label>
        <div class="field-wrap"><i class="ti ti-tool fi"></i><input id="acesso-ferramenta" placeholder="ex: Octadesk, Atende Simples…" autocomplete="off"></div>
      </div>
      <div class="field" style="margin-bottom:10px">
        <label>Login / E-mail</label>
        <div class="field-wrap"><i class="ti ti-at fi"></i><input id="acesso-login" placeholder="login ou e-mail" autocomplete="off"></div>
      </div>
      <div class="field" style="margin-bottom:14px">
        <label>Senha</label>
        <div class="field-wrap">
          <i class="ti ti-lock fi"></i>
          <input id="acesso-senha" type="password" placeholder="senha" autocomplete="new-password">
          <button type="button" class="toggle-pw" onclick="togglePwAcesso(this)"><i class="ti ti-eye"></i></button>
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button onclick="salvarAcesso()" style="flex:1;background:var(--gold);color:var(--on-gold,#1A1A18);border:none;border-radius:var(--rs);padding:9px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer">Salvar</button>
        <button onclick="cancelarFormAcesso()" style="background:none;border:1px solid var(--border);border-radius:var(--rs);padding:9px 14px;font-size:12px;color:var(--text-muted);font-family:inherit;cursor:pointer">Cancelar</button>
      </div>
      <div id="acesso-erro" style="display:none;font-size:11px;color:var(--bad-text);margin-top:8px"></div>
    </div>
  </div>
</div>

<!-- MODAL HISTÓRICO AUDITORIAS -->
<div class="modal-overlay" id="modal-auditorias" onclick="if(event.target===this)fecharHistoricoAuditoria()">
  <div class="modal-box" style="max-width:520px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <div>
        <div style="font-size:15px;font-weight:700"><i class="ti ti-clipboard-list" style="color:var(--gold);margin-right:6px"></i>Auditorias</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px" id="audit-modal-periodo"></div>
      </div>
      <div style="display:flex;align-items:center;gap:10px">
        <div id="audit-modal-nota" style="font-size:22px;font-weight:800"></div>
        <button onclick="fecharHistoricoAuditoria()" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;padding:4px"><i class="ti ti-x"></i></button>
      </div>
    </div>
    <div id="audit-modal-lista" style="display:flex;flex-direction:column;gap:8px;max-height:420px;overflow-y:auto;padding-right:2px"></div>
  </div>
</div>

<script>
  // Injetado pelo servidor a partir da sessão — não existe mais tela de login
  // nesta página, o hub já autenticou o usuário antes de chegar aqui.
  window.USUARIO_SESSAO = <%- JSON.stringify(usuarioAtual) %>;
  window.OUTROS_COLABORADORES = <%- JSON.stringify(outrosColaboradores) %>;
</script>
<script src="/js/painel-sac.js"></script>
</body>
</html>
