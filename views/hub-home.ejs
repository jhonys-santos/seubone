<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('partials/head') %>
<title>SeuBoné</title>
</head>
<body>
<div class="app-shell">
<%- include('partials/sidebar') %>
<div class="app-main">
<div class="hub-container">
  <div class="hub-welcome">
    <h1>Olá, <%= usuario.nome.split(' ')[0] %></h1>
    <p>Painéis disponíveis para o seu acesso.</p>
  </div>
  <% if (paineisVisiveis.length === 0) { %>
    <div class="hub-empty">
      <i class="ti ti-lock" aria-hidden="true"></i>
      Nenhum painel liberado para o seu usuário ainda. Fale com seu gestor.
    </div>
  <% } else { %>
  <div class="hub-grid">
    <% paineisVisiveis.forEach(function(p) { %>
      <a class="hub-card" href="<%= p.url %>">
        <div class="hub-card-icon"><i class="ti <%= p.icone %>" aria-hidden="true"></i></div>
        <div>
          <h3><%= p.titulo %></h3>
          <p><%= p.descricao %></p>
        </div>
        <div class="hub-card-footer">Abrir <i class="ti ti-arrow-right" aria-hidden="true"></i></div>
      </a>
    <% }); %>
  </div>

  <% if (atalhosVisiveis.length) { %>
  <div class="hub-section-label">Atalhos</div>
  <div class="hub-grid">
    <% atalhosVisiveis.forEach(function(a) { %>
      <a class="hub-card" href="<%= a.url %>" <% if (a.novaAba) { %>target="_blank" rel="noopener"<% } %>>
        <% if (a.novaAba) { %><span class="hub-card-external-badge"><i class="ti ti-external-link" aria-hidden="true"></i></span><% } %>
        <div class="hub-card-icon"><i class="ti <%= a.icone %>" aria-hidden="true"></i></div>
        <div>
          <h3><%= a.titulo %></h3>
          <p><%= a.descricao %></p>
        </div>
        <div class="hub-card-footer"><%= a.novaAba ? 'Abrir em nova aba' : 'Abrir' %> <i class="ti ti-arrow-right" aria-hidden="true"></i></div>
      </a>
    <% }); %>
  </div>
  <% } %>
  <% } %>
</div>
</div>
</div>
</body>
</html>
