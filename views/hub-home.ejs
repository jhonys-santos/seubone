<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('partials/head') %>
<title>SeuBoné</title>
</head>
<body>
<div class="app-shell">
<%- include('partials/sidebar') %>
<div class="app-main">
<div class="hub-container">
  <div class="hub-welcome">
    <h1>Olá, <%= usuario.nome.split(' ')[0] %></h1>
    <p>Painéis disponíveis para o seu acesso.</p>
  </div>
  <% if (paineisVisiveis.length === 0) { %>
    <div class="hub-empty">
      <i class="ti ti-lock" aria-hidden="true"></i>
      Nenhum painel liberado para o seu usuário ainda. Fale com seu gestor.
    </div>
  <% } else { %>
  <div class="hub-grid">
    <% paineisVisiveis.forEach(function(p) { %>
      <a class="hub-card" href="<%= p.url %>">
        <div class="hub-card-icon"><i class="ti <%= p.icone %>" aria-hidden="true"></i></div>
        <div>
          <h3><%= p.titulo %></h3>
          <p><%= p.descricao %></p>
        </div>
        <div class="hub-card-footer">Abrir <i class="ti ti-arrow-right" aria-hidden="true"></i></div>
      </a>
    <% }); %>
  </div>

  <% if (atalhosVisiveis.length) { %>
  <div class="hub-section-label">Atalhos</div>
  <div class="hub-grid">
    <% atalhosVisiveis.forEach(function(a) { %>
      <a class="hub-card" href="<%= a.url %>" <% if (a.novaAba) { %>target="_blank" rel="noopener"<% } %>>
        <% if (a.novaAba) { %><span class="hub-card-external-badge"><i class="ti ti-external-link" aria-hidden="true"></i></span><% } %>
        <div class="hub-card-icon"><i class="ti <%= a.icone %>" aria-hidden="true"></i></div>
        <div>
          <h3><%= a.titulo %></h3>
          <p><%= a.descricao %></p>
        </div>
        <div class="hub-card-footer"><%= a.novaAba ? 'Abrir em nova aba' : 'Abrir' %> <i class="ti ti-arrow-right" aria-hidden="true"></i></div>
      </a>
    <% }); %>
  </div>
  <% } %>
  <% } %>
</div>
</div>
</div>

<% if (paineisVisiveis.some(function (p) { return p.chave === 'painel-sac'; })) { %>
<div class="popup-overlay" id="popup-aviso">
  <div class="popup-box">
    <div class="popup-icon-row">
      <div class="popup-icon"><i class="ti ti-bell-ringing" style="font-size:20px;color:var(--gold)"></i></div>
      <div class="popup-title-text" id="av-titulo"></div>
    </div>
    <div class="popup-body-text" id="av-corpo"></div>
    <div class="popup-footer">
      <span class="popup-meta" id="av-meta"></span>
      <button class="popup-btn-primary" onclick="fecharPopup('popup-aviso')">Entendido ✓</button>
    </div>
  </div>
</div>
<script>
  fetch('/painel-sac/api/aviso').then(function (r) { return r.json(); }).then(function (d) {
    if (d.aviso && d.aviso.ativo) setTimeout(function () { abrirAviso(d.aviso); }, 700);
  }).catch(function () {});
</script>
<% } %>
</body>
</html>
