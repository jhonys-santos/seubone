<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('../partials/head') %>
<title>Premiação — Produção SBP — SeuBoné</title>
<link rel="stylesheet" href="/css/wallac.css">
<link rel="stylesheet" href="/css/wallac-premiacao.css">
</head>
<body>
<div class="app-shell">
<%- include('../partials/sidebar') %>
<div class="app-main">

<div class="wallac-container">
  <div class="wallac-header">
    <h2><i class="ti ti-award" aria-hidden="true"></i> Premiação — SB Coin</h2>
  </div>
  <p class="premiacao-subtitulo">Fechamento semanal automático · peças finalizadas dentro do prazo de produção (PPF).</p>

  <div class="premiacao-semana-atual" id="premiacao-semana-atual">
    <div class="premiacao-semana-atual-topo">
      <div class="premiacao-semana-atual-titulo">
        <i class="ti ti-bolt" aria-hidden="true"></i> Semana atual (em andamento)
      </div>
      <span class="selo-faixa nenhuma" id="semana-atual-faixa">—</span>
    </div>
    <div class="premiacao-semana-atual-pecas">
      <strong id="semana-atual-pecas">—</strong> <span>peças no prazo até agora</span>
    </div>
    <div class="premiacao-progresso-bar">
      <div class="premiacao-progresso-fill" id="progresso-fill"></div>
      <div class="premiacao-progresso-marca" style="left:30%"></div>
      <div class="premiacao-progresso-marca" style="left:50%"></div>
      <div class="premiacao-progresso-marca" style="left:80%"></div>
    </div>
    <div class="premiacao-progresso-legendas">
      <span style="left:0%">0</span>
      <span style="left:30%">Bronze · 30</span>
      <span style="left:50%">Prata · 50</span>
      <span style="left:80%">Ouro · 80</span>
    </div>
    <div class="premiacao-semana-atual-nota" id="semana-atual-nota">Carregando...</div>
  </div>

  <div class="premiacao-resumo">
    <div class="premiacao-resumo-topo">
      <div class="premiacao-resumo-titulo" id="mes-atual">Carregando...</div>
      <div class="premiacao-resumo-coins" id="coins-mes">- <span>coins no mês</span></div>
    </div>
  </div>

  <div class="premiacao-table-wrap">
    <table class="premiacao-table">
      <thead>
        <tr>
          <th>Semana</th>
          <th>Peças no prazo</th>
          <th>Faixa</th>
          <th>Coins</th>
        </tr>
      </thead>
      <tbody id="corpo-tabela">
        <tr><td colspan="4" class="premiacao-vazio">Carregando...</td></tr>
      </tbody>
    </table>
  </div>
</div>

</div>
</div>

<script src="/js/wallac-premiacao.js"></script>
</body>
</html>
