<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('../partials/head') %>
<title>Histórico — Registro de Demandas Gerais — SeuBoné</title>
<link rel="stylesheet" href="/css/pedidos-urgentes.css">
</head>
<body>
<div class="app-shell">
<%- include('../partials/sidebar') %>
<div class="app-main">

<div class="pu-scope">
<div class="pu-container">
  <div class="filters">
    <div>
      <label>De</label>
      <input type="date" id="ft-de">
    </div>
    <div>
      <label>Até</label>
      <input type="date" id="ft-ate">
    </div>
    <div>
      <label>Status</label>
      <select id="ft-status">
        <option value="">Todos</option>
        <option value="Pendente">Pendentes</option>
        <option value="Feito">Feitos</option>
      </select>
    </div>
    <div>
      <label>Empresa</label>
      <select id="ft-empresa">
        <option value="">Todas</option>
        <option>SeuBoné</option>
      </select>
    </div>
    <div>
      <label>Demanda solicitada</label>
      <select id="ft-demanda">
        <option value="">Todas</option>
        <option>NF Urgente</option>
        <option>Nota de Remessa</option>
        <option>Baixa de comprovante</option>
        <option>Análise de termo de compromisso</option>
        <option>Nota de Conta e Ordem</option>
        <option>Link de pagamento</option>
        <option>Orçamento - Extrema/MG</option>
        <option>Ajuste de nota fiscal</option>
        <option>Ajuste de orçamento</option>
        <option>Envio de boleto</option>
        <option>Liberação p/envio</option>
        <option>Nota de Devolução</option>
        <option>Amostras</option>
        <option>Nota de Brinde</option>
        <option>Manifesto</option>
        <option>Cancelamento de Boleto</option>
        <option>Pedidos retidos</option>
        <option>Outros</option>
      </select>
    </div>
    <div>
      <label>Buscar (solicitante ou ID da venda)</label>
      <input type="text" id="ft-busca" placeholder="Digite pra filtrar">
    </div>
    <div>
      <button class="btn-primary" id="btn-filtrar" style="margin-top:0;width:auto;"><i class="ti ti-filter" aria-hidden="true"></i> Filtrar</button>
    </div>
  </div>

  <div id="tabela">
    <table>
      <thead>
        <tr>
          <th>Data solicitação</th>
          <th>ID venda</th>
          <th>Card</th>
          <th>Solicitante</th>
          <th>Demanda</th>
          <th>Descrição</th>
          <th>Anexos</th>
          <th>Status</th>
          <th>Feito por</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
    <div class="empty" id="empty" style="display:none">Nenhuma solicitação encontrada no período.</div>
  </div>
</div>
</div>

</div>
</div>

<script src="/js/registro-demandas-historico.js"></script>
</body>
</html>
