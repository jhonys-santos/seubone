<aside class="app-sidebar">
  <a href="/" class="sidebar-brand">
    <img src="/img/logo-seubone.png" alt="SeuBoné">
    <span class="sidebar-brand-text">Seu<span class="gold">Boné</span></span>
  </a>

  <% if (typeof usuario !== 'undefined' && usuario) { %>
  <div class="sidebar-user">
    <div class="hub-avatar"><%= usuario.nome.split(' ').filter(Boolean).slice(0,2).map(w => w[0]).join('').toUpperCase() %></div>
    <div class="sidebar-user-text">
      <span class="sidebar-user-name"><%= usuario.nome %></span>
      <span class="sidebar-role-badge"><%= usuario.role %></span>
    </div>
  </div>
  <% } %>

  <nav class="sidebar-nav">
    <a href="/" class="sidebar-item <%= rotaAtual === '/' ? 'active' : '' %>">
      <i class="ti ti-home" aria-hidden="true"></i> Home
    </a>

    <% if (paineisVisiveis.length) { %>
      <div class="sidebar-label">Painéis</div>
      <% paineisVisiveis.forEach(function (p) { %>
        <%
          var subVisiveis = (p.subpaginas || []).filter(function (s) { return !s.somenteSlug || s.somenteSlug === usuario.slug; });
          var subAtiva = subVisiveis.some(function (s) { return rotaAtual === s.url; });
        %>
        <% if (subVisiveis.length) { %>
          <div class="sidebar-group <%= subAtiva ? 'open' : '' %>">
            <div class="sidebar-item-row">
              <a href="<%= p.url %>" class="sidebar-item <%= !subAtiva && rotaAtual === p.url ? 'active' : '' %>">
                <i class="ti <%= p.icone %>" aria-hidden="true"></i> <%= p.titulo %>
              </a>
              <button type="button" class="sidebar-chev" onclick="alternarGrupoSidebar(this)" aria-label="Expandir <%= p.titulo %>">
                <i class="ti ti-chevron-right" aria-hidden="true"></i>
              </button>
            </div>
            <div class="sidebar-sub">
              <div class="sidebar-sub-inner">
                <% subVisiveis.forEach(function (s) { %>
                  <a href="<%= s.url %>" class="sidebar-item sidebar-subitem <%= rotaAtual === s.url ? 'active' : '' %>">
                    <i class="ti <%= s.icone || 'ti-point' %>" aria-hidden="true"></i> <%= s.titulo %>
                  </a>
                <% }); %>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="<%= p.url %>" class="sidebar-item <%= rotaAtual === p.url ? 'active' : '' %>">
            <i class="ti <%= p.icone %>" aria-hidden="true"></i> <%= p.titulo %>
          </a>
        <% } %>
      <% }); %>
    <% } %>

    <% if (atalhosVisiveis.length) { %>
      <div class="sidebar-label">Atalhos</div>
      <% atalhosVisiveis.forEach(function (a) { %>
        <a href="<%= a.url %>" class="sidebar-item" <% if (a.novaAba) { %>target="_blank" rel="noopener"<% } %>>
          <i class="ti <%= a.icone %>" aria-hidden="true"></i> <%= a.titulo %>
        </a>
      <% }); %>
    <% } %>

    <% if (typeof usuario !== 'undefined' && usuario) { %>
    <div class="sidebar-label">Conta</div>
    <a href="/perfil" class="sidebar-item <%= rotaAtual === '/perfil' ? 'active' : '' %>">
      <i class="ti ti-user-cog" aria-hidden="true"></i> Perfil
    </a>
    <% if (paineisVisiveis.some(function (p) { return p.chave === 'painel-sac'; })) { %>
    <button type="button" class="sidebar-item" onclick="abrirAcessos()">
      <i class="ti ti-key" aria-hidden="true"></i> Acessos
    </button>
    <% } %>
    <% } %>
  </nav>

  <div class="sidebar-bottom">
    <button type="button" class="hub-theme-toggle" onclick="alternarTema()">
      <i class="ti ti-sun" data-tema-icon aria-hidden="true"></i> <span data-tema-label>Claro</span>
    </button>
    <% if (typeof usuario !== 'undefined' && usuario) { %>
    <form action="/logout" method="POST" style="margin:0;">
      <button type="submit" class="hub-logout">
        <i class="ti ti-logout-2" aria-hidden="true"></i> Sair
      </button>
    </form>
    <% } %>
  </div>
</aside>

<% if (typeof usuario !== 'undefined' && usuario && paineisVisiveis.some(function (p) { return p.chave === 'painel-sac'; })) { %>
<!-- MODAL ACESSOS -->
<div class="modal-overlay" id="modal-acessos" onclick="if(event.target===this)fecharAcessos()">
  <div class="modal-box" style="max-width:480px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <div>
        <div style="font-size:15px;font-weight:700"><i class="ti ti-key" style="color:var(--gold);margin-right:6px"></i>Acessos</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px">Suas credenciais de ferramentas</div>
      </div>
      <button onclick="fecharAcessos()" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1;padding:4px"><i class="ti ti-x"></i></button>
    </div>

    <div id="acessos-lista" style="margin-bottom:1rem;display:flex;flex-direction:column;gap:8px;max-height:340px;overflow-y:auto;padding-right:2px"></div>

    <button id="btn-add-acesso" onclick="mostrarFormAcesso()" style="width:100%;background:var(--gold-dim);border:1px dashed var(--gold-dark);border-radius:var(--radius-sm);padding:10px;font-size:12px;font-weight:600;color:var(--gold);cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .15s">
      <i class="ti ti-plus"></i> Adicionar acesso
    </button>

    <div id="form-acesso" style="display:none;margin-top:12px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px">
      <div style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--text)" id="form-acesso-titulo">Novo acesso</div>
      <input type="hidden" id="acesso-edit-idx" value="">
      <div class="field" style="margin-bottom:10px">
        <label>Ferramenta</label>
        <div class="field-wrap"><i class="ti ti-tool fi"></i><input id="acesso-ferramenta" placeholder="ex: Octadesk, Atende Simples…" autocomplete="off"></div>
      </div>
      <div class="field" style="margin-bottom:10px">
        <label>Login / E-mail</label>
        <div class="field-wrap"><i class="ti ti-at fi"></i><input id="acesso-login" placeholder="login ou e-mail" autocomplete="off"></div>
      </div>
      <div class="field" style="margin-bottom:14px">
        <label>Senha</label>
        <div class="field-wrap">
          <i class="ti ti-lock fi"></i>
          <input id="acesso-senha" type="password" placeholder="senha" autocomplete="new-password">
          <button type="button" class="toggle-pw" onclick="togglePwAcesso(this)"><i class="ti ti-eye"></i></button>
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button onclick="salvarAcesso()" style="flex:1;background:var(--gold);color:var(--on-gold,#1A1A18);border:none;border-radius:var(--radius-sm);padding:9px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer">Salvar</button>
        <button onclick="cancelarFormAcesso()" style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 14px;font-size:12px;color:var(--text-muted);font-family:inherit;cursor:pointer">Cancelar</button>
      </div>
      <div id="acesso-erro" style="display:none;font-size:11px;color:var(--bad-text);margin-top:8px"></div>
    </div>
  </div>
</div>
<% } %>
