<!DOCTYPE html>
<html lang="pt-BR">
<head>
<%- include('../partials/head') %>
<title>Quitações Pendentes — SeuBoné</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/pedidos-urgentes.css">
<link rel="stylesheet" href="/css/quitacoes.css">
</head>
<body>
<div class="app-shell">
<%- include('../partials/sidebar') %>
<div class="app-main">

<div class="pu-scope">
<div class="pu-container">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
    <div style="font-size:12px;color:var(--text-hint);">
      <% if (usuario.role === 'gestor') { %>Todos os pedidos aguardando quitação do cliente<% } else { %>Seus pedidos aguardando quitação do cliente<% } %>
    </div>
    <button class="btn-secondary" onclick="carregar()"><i class="ti ti-refresh" aria-hidden="true"></i> Atualizar</button>
  </div>

  <div class="stats">
    <div class="stat"><div class="n" id="statTotal">-</div><div class="l">pendentes de quitação</div></div>
    <div class="stat danger"><div class="n" id="statAtrasados">-</div><div class="l">atrasados</div></div>
    <div class="stat"><div class="n" id="statFrete">-</div><div class="l">com frete dedicado</div></div>
  </div>

  <div id="lista"></div>
</div>
</div>

</div>
</div>

<script>window.QT_USUARIO_ROLE = <%- JSON.stringify(usuario.role) %>;</script>
<script src="/js/quitacoes-painel.js"></script>
</body>
</html>
